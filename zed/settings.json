{
  "status_bar": {
    "active_language_button": true,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "left",
    "default_profile": "write",
    "default_model": {
      "model": "qwen/qwen3.5-35b-a3b",
      "provider": "lmstudio",
    },
  },
  "buffer_font_family": "DejaVu Sans Mono",
  "buffer_font_size": 12,
  "icon_theme": "Catppuccin Mocha",
  "languages": {
    "Ruby": {
      "wrap_guides": [120],
    },
  },
  "soft_wrap": "editor_width",
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system",
  },
  "ui_font_size": 16,
  "vim": {
    "use_system_clipboard": "always",
  },
  "vim_mode": true,
}
