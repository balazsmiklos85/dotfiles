#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'

# --- Configuration: Pricing per 1M tokens (USD) ---
PRICING = {
  'claude-opus-4-5' => { input: 5.0, output: 25.0, cache_read: 0.50, cache_creat: 6.25 },
  'claude-opus-4-6' => { input: 5.0, output: 25.0, cache_read: 0.50, cache_creat: 6.25 },
  'claude-opus-4-1' => { input: 15.0, output: 75.0, cache_read: 1.50, cache_creat: 18.75 },
  'claude-opus-4' => { input: 15.0, output: 75.0, cache_read: 1.50, cache_creat: 18.75 },
  'claude-sonnet-4-5' => { input: 3.0, output: 15.0, cache_read: 0.30, cache_creat: 3.75 },
  'claude-sonnet-4-6' => { input: 3.0, output: 15.0, cache_read: 0.30, cache_creat: 3.75 },
  'claude-sonnet-4' => { input: 3.0, output: 15.0, cache_read: 0.30, cache_creat: 3.75 },
  'claude-haiku-4-5' => { input: 1.0, output: 5.0, cache_read: 0.10, cache_creat: 1.25 },
  'claude-haiku-3-5' => { input: 0.80, output: 4.0, cache_read: 0.08, cache_creat: 1.0 },
  'claude-haiku-3' => { input: 0.25, output: 1.25, cache_read: 0.03, cache_creat: 0.30 }
}.freeze

def normalize_model_name(full_name)
  if full_name =~ /(claude-(?:opus|sonnet|haiku)-\d+-\d+)/
    Regexp.last_match(1)
  else
    full_name
  end
end

file_path = File.expand_path('~/.claude/stats-cache.json')

unless File.exist?(file_path)
  puts "Error: File not found at #{file_path}"
  exit 1
end

data = JSON.parse(File.read(file_path))
usage_stats = data['modelUsage']

totals = Hash.new { |h, k| h[k] = Hash.new(0) }

usage_stats.each do |full_name, stats|
  name = normalize_model_name(full_name)
  totals[name][:input] += stats['inputTokens']
  totals[name][:output] += stats['outputTokens']
  totals[name][:cache_read] += stats['cacheReadInputTokens']
  totals[name][:cache_creat] += stats['cacheCreationInputTokens']
end

puts '-' * 72
puts format('%-20s | %-10s | %-10s | %-10s', 'Model Family', 'Input (M)', 'Output (M)', 'Cost (USD)')
puts '-' * 72

grand_total = 0.0

totals.each do |model, s|
  rates = PRICING[model] || { input: 0, output: 0, cache_read: 0, cache_creat: 0 }

  input_cost = (s[:input] / 1_000_000.0) * rates[:input]
  output_cost = (s[:output] / 1_000_000.0) * rates[:output]
  read_cost  = (s[:cache_read] / 1_000_000.0) * rates[:cache_read]
  creat_cost = (s[:cache_creat] / 1_000_000.0) * rates[:cache_creat]

  model_cost = input_cost + output_cost + read_cost + creat_cost
  grand_total += model_cost

  puts format('%-20s | %-10.4f | %-10.4f | $%-9.2f', model, s[:input] / 1_000_000.0, s[:output] / 1_000_000.0,
              model_cost)
end

puts '-' * 72
puts "GRAND TOTAL COST: $#{'%.2f' % grand_total}"
