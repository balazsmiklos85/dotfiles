#!/usr/bin/env ruby
# frozen_string_literal: true

puts 'Clean...'
`gw clean`

puts 'Build...'
build_output = `gw build 2>&1 | rg -U '^> Task|Failed to load ApplicationContext' | rg -v 'UP-TO-DATE|SKIPPED|NO-SOURCE'`

case build_output
when /> Task :\w+:compile\w+ FAILED/
  puts 'Compile...'
  puts `gw compileJava compileTestJava --console=plain 2>&1 | rg -A 4 '^/.*java:\\d+: error'`
when /spotbugs.*FAILED/
  puts `w3m service/build/reports/spotbugs/*.html | awk '/Code[[:space:]]+Warning/,/Details/' | rg -v 'Details'`
when /ApplicationContext/
  puts 'Spring context issues:'
  puts `fd -u '(Test|IT)\\.html' | xargs -I {} rg 'NoSuchBeanDefinitionException' {} | uniq`
when /([tT]est|IT).*FAILED/
  puts 'Test failures:'
  puts `fd -u '(Test|IT)\\.html' | xargs -I {} rg -l 'Failed tests' {} | xargs w3m | awk '/^Failed tests/,/Test/' | rg -v '(Failed tests|Test)'`
else
  puts build_output
end
