set editor = "nvim"
auto_view text/html
set from = "Balázs Miklós <`pass mail/personal/gmail/user`@gmail.com>"

# IMAP settings
set imap_user = "`pass mail/personal/gmail/user`@gmail.com"
set imap_pass = "`pass mail/personal/gmail/password`"
set folder = "imaps://imap.gmail.com"
set spoolfile = "+INBOX"
# set record = "+[Gmail]/Elküldött levelek"
set postponed = "+[Gmail]/Piszkozatok"
set trash = "+[Gmail]/Kuka"

mailboxes =INBOX =[Gmail]/Elküldött\ levelek =[Gmail]/Piszkozatok =[Gmail]/Spam =[Gmail]/Kuka =[Gmail]/Összes\ levél

bind editor <space> noop
macro index A '<save-message>=[Gmail]/Összes levél<enter>' 'Archive'
macro index S '<save-message>=[Gmail]/Spam<enter>' 'Spam'

set header_cache = ~/.cache/neomutt/header/
set message_cache_dir = ~/.cache/neomutt/body

# SMTP settings
set smtp_url = "smtp://`pass mail/personal/gmail/user`@smtp.gmail.com:587/"
set smtp_pass = "`pass mail/personal/gmail/password`"

# Securing
set ssl_force_tls = yes
# To avoid certificate errors
set ssl_starttls=yes
set ssl_use_sslv3=no
set ssl_use_tlsv1=no
set ssl_use_tlsv1_1=no
set ssl_use_tlsv1_2=yes
set ssl_verify_dates=yes
set ssl_verify_host=yes

color normal		  default default         # Text is "Text"
color index		    color209 default ~N     # New Messages are Orange
color index		    color166 default ~F     # Flagged messages are Dark Orange
color index		    color209 default ~T     # Tagged Messages are Orange
color index		    color166 default ~D     # Messages to delete are Dark Orange
color attachment	color208 default        # Attachments are Bright Orange
color signature	  color209 default        # Signatures are Orange
color search		  color209 default        # Highlighted results are Orange

color indicator		color233 color216       # currently highlighted message Orange=Text Dark Gray=Background
color error		    color166 default        # error messages are Dark Orange
color status		  color208 default        # status line Bright Orange
color tree        color208 default        # thread tree arrows Bright Orange
color tilde       color208 default        # blank line padding Bright Orange

color hdrdefault  color209 default        # default headers Orange
color header		  color209 default "^From:"
color header	 	  color209 default "^Subject:"

color quoted		  color208 default        # Subtext 0
color quoted1		  color166 default        # Subtext 1
color quoted2		  color209 default        # Surface 2
color quoted3		  color246 default        # Surface 1
color quoted4		  color246 default
color quoted5		  color246 default

color body		color209 default		[\-\.+_a-zA-Z0-9]+@[\-\.a-zA-Z0-9]+               # email addresses Orange
color body	  color209 default		(https?|ftp)://[\-\.,/%~_:?&=\#a-zA-Z0-9]+        # URLs Orange
color body		color166 default		(^|[[:space:]])\\*[^[:space:]]+\\*([[:space:]]|$) # *bold* text Dark Orange
color body		color166 default		(^|[[:space:]])_[^[:space:]]+_([[:space:]]|$)     # _underlined_ text Dark Orange
color body		color166 default		(^|[[:space:]])/[^[:space:]]+/([[:space:]]|$)     # /italic/ text Dark Orange

color sidebar_flagged   color166 default    # Mailboxes with flagged mails are Dark Orange
color sidebar_new       color209 default    # Mailboxes with new mail are Orange

