set editor = "nvim"
auto_view text/html
set from = "BALÁZS Miklós <`pass mail/m/gmail/user`>"

# IMAP settings
set imap_user = "`pass mail/m/gmail/user`"
set imap_pass = "`pass mail/m/gmail/password`"
set folder = "imaps://imap.gmail.com"
set spoolfile = "+INBOX"
# set record = "+[Gmail]/Elküldött levelek"
set postponed = "+[Gmail]/Piszkozatok"
set trash = "+[Gmail]/Kuka"

mailboxes =INBOX =[Gmail]/Elküldött\ levelek =[Gmail]/Piszkozatok =[Gmail]/Spam =[Gmail]/Kuka =[Gmail]/Összes\ levél

bind editor <space> noop
macro index A '<save-message>=[Gmail]/Összes levél<enter>' 'Archive'

set header_cache = ~/.cache/neomutt/header/
set message_cache_dir = ~/.cache/neomutt/body

# SMTP settings
set smtp_url = "smtp://`pass mail/m/gmail/user`@smtp.gmail.com:587/"
set smtp_pass = "`pass mail/m/gmail/password`"

# Securing
set ssl_force_tls = yes
# To avoid certificate errors
set ssl_starttls=yes
set ssl_use_sslv3=no
set ssl_use_tlsv1=no
set ssl_use_tlsv1_1=no
set ssl_use_tlsv1_2=yes
set ssl_verify_dates=yes
set ssl_verify_host=yes

color normal		  default default         # Text is "Text"
color index		    color178 default ~N     # New Messages are Dark Yellow
color index		    color136 default ~F     # Flagged messages are Dark Golden
color index		    color178 default ~T     # Tagged Messages are Dark Yellow
color index		    color136 default ~D     # Messages to delete are Dark Golden
color attachment	color220 default        # Attachments are Bright Yellow
color signature	  color178 default        # Signatures are Dark Yellow
color search		  color178 default        # Highlighted results are Dark Yellow

color indicator		color233 color220       # currently highlighted message Bright Yellow=Text Dark Gray=Background
color error		    color136 default        # error messages are Dark Golden
color status		  color220 default        # status line Bright Yellow
color tree        color220 default        # thread tree arrows Bright Yellow
color tilde       color220 default        # blank line padding Bright Yellow

color hdrdefault  color178 default        # default headers Dark Yellow
color header		  color178 default "^From:"
color header	 	  color178 default "^Subject:"

color quoted		  color220 default        # Subtext 0
color quoted1		  color136 default        # Subtext 1
color quoted2		  color178 default        # Surface 2
color quoted3		  color246 default        # Surface 1
color quoted4		  color246 default
color quoted5		  color246 default

color body		color178 default		[\-\.+_a-zA-Z0-9]+@[\-\.a-zA-Z0-9]+               # email addresses Dark Yellow
color body	  color178 default		(https?|ftp)://[\-\.,/%~_:?&=\#a-zA-Z0-9]+        # URLs Dark Yellow
color body		color136 default		(^|[[:space:]])\\*[^[:space:]]+\\*([[:space:]]|$) # *bold* text Dark Golden
color body		color136 default		(^|[[:space:]])_[^[:space:]]+_([[:space:]]|$)     # _underlined_ text Dark Golden
color body		color136 default		(^|[[:space:]])/[^[:space:]]+/([[:space:]]|$)     # /italic/ text Dark Golden

color sidebar_flagged   color136 default    # Mailboxes with flagged mails are Dark Golden
color sidebar_new       color178 default    # Mailboxes with new mail are Dark Yellow

